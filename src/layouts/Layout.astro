---
import '@/styles/global.css';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/webp" href="/imc-logo.webp" />
    <link rel="icon" href="/imc-logo.webp" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content="Imcarrows: importacion premium de vehiculos desde Alemania a Espana con inspeccion tecnica, logistica segura y legalizacion integral."
    />
    <title>Imcarrows | Importacion premium Alemania - Espana</title>
  </head>
  <body class="bg-imc-black text-imc-silver antialiased">
    <slot />

    <button
      type="button"
      data-back-to-top
      class="back-to-top fixed bottom-6 right-6 z-50 inline-flex h-11 w-11 items-center justify-center rounded-full border border-imc-yellow/60 bg-imc-black/85 text-imc-yellow shadow-[0_12px_30px_rgba(0,0,0,0.45)] backdrop-blur-sm transition hover:border-imc-yellow hover:bg-imc-yellow hover:text-imc-black"
      aria-label="Volver arriba"
    >
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-5 w-5" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 15l6-6 6 6" />
      </svg>
    </button>

    <script is:inline>
      const backToTopButton = document.querySelector('[data-back-to-top]');

      if (backToTopButton instanceof HTMLButtonElement) {
        const toggleVisibility = () => {
          const shouldShow = window.scrollY > 320;
          backToTopButton.classList.toggle('is-visible', shouldShow);
        };

        backToTopButton.addEventListener('click', () => {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });

        toggleVisibility();
        window.addEventListener('scroll', toggleVisibility, { passive: true });
      }
    </script>

    <style>
      .back-to-top {
        opacity: 0;
        transform: translate3d(0, 16px, 0);
        pointer-events: none;
      }

      .back-to-top.is-visible {
        opacity: 1;
        transform: translate3d(0, 0, 0);
        pointer-events: auto;
      }

      @media (prefers-reduced-motion: reduce) {
        .back-to-top {
          transition: none;
        }
      }
    </style>
  </body>
</html>
