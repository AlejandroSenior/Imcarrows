---
import '@/styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
}

const {
  title = 'Imcarrows | Importación Alemania - España',
  description =
    'Imcarrows: importación de vehículos desde Alemania a España con inspección técnica, logística segura y legalización integral.',
  image = '/imc-logo.webp',
  type = 'website',
  noindex = false
} = Astro.props;

const siteUrl = Astro.site ?? new URL('https://imcarrows.com');
const pageUrl = new URL(Astro.url.pathname, siteUrl).toString();
const imageUrl = new URL(image, siteUrl).toString();
const robots = noindex ? 'noindex, nofollow' : 'index, follow';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/webp" href="/imc-logo.webp" />
    <link rel="icon" href="/imc-logo.webp" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <meta name="author" content="Imcarrows" />
    <meta name="theme-color" content="#090909" />

    <link rel="canonical" href={pageUrl} />
    <link rel="preconnect" href="https://images.unsplash.com" crossorigin="anonymous" />

    <meta property="og:locale" content="es_ES" />
    <meta property="og:site_name" content="Imcarrows" />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:alt" content="Imcarrows, importación de coches desde Alemania a España" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@imcarrows" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />

    <slot name="head" />

    <title>{title}</title>
  </head>
  <body class="bg-imc-black text-imc-silver antialiased">
    <slot />

    <button
      type="button"
      data-back-to-top
      class="back-to-top fixed bottom-6 right-6 z-50 inline-flex h-11 w-11 items-center justify-center rounded-full border border-imc-yellow/60 bg-imc-black/85 text-imc-yellow shadow-[0_12px_30px_rgba(0,0,0,0.45)] backdrop-blur-sm transition hover:border-imc-yellow hover:bg-imc-yellow hover:text-imc-black"
      aria-label="Volver arriba"
    >
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-5 w-5" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 15l6-6 6 6"></path>
      </svg>
    </button>

    <script is:inline>
      const backToTopButton = document.querySelector('[data-back-to-top]');

      if (backToTopButton instanceof HTMLButtonElement) {
        const toggleVisibility = () => {
          const shouldShow = window.scrollY > 320;
          backToTopButton.classList.toggle('is-visible', shouldShow);
        };

        backToTopButton.addEventListener('click', () => {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });

        toggleVisibility();
        window.addEventListener('scroll', toggleVisibility, { passive: true });
      }
    </script>

    <style>
      .back-to-top {
        opacity: 0;
        transform: translate3d(0, 16px, 0);
        pointer-events: none;
      }

      .back-to-top.is-visible {
        opacity: 1;
        transform: translate3d(0, 0, 0);
        pointer-events: auto;
      }

      @media (prefers-reduced-motion: reduce) {
        .back-to-top {
          transition: none;
        }
      }
    </style>
  </body>
</html>
