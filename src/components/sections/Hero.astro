---
import Rrss from '@/components/Rrss.astro';
---

<section id="hero" class="relative isolate overflow-hidden bg-[#090909] pt-24">
  <div
    class="absolute inset-0 -z-30 bg-[radial-gradient(circle_at_50%_10%,rgba(255,255,255,0.14),transparent_35%),linear-gradient(180deg,#0b0b0b_0%,#050505_100%)]"
  >
  </div>
  <img
    src="https://images.unsplash.com/photo-1503376780353-7e6692767b70?auto=format&fit=crop&w=1800&q=80"
    alt="Coche deportivo fotografiado de perfil en un estudio oscuro"
    class="absolute inset-y-0 right-0 -z-20 h-full w-full object-cover object-[72%_center] opacity-45 lg:w-[70%] lg:opacity-80"
    loading="eager"
  />
  <div
    class="absolute inset-0 -z-10 bg-[linear-gradient(90deg,rgba(5,5,5,0.96)_0%,rgba(5,5,5,0.86)_38%,rgba(5,5,5,0.45)_62%,rgba(5,5,5,0.92)_100%)]"
  >
  </div>
  <div class="absolute inset-x-0 bottom-0 -z-10 h-40 bg-[linear-gradient(180deg,rgba(5,5,5,0)_0%,rgba(5,5,5,0.95)_70%,#111_100%)]"></div>

  <div class="mx-auto flex min-h-180 w-full max-w-7xl flex-col px-6 pb-0 pt-10 lg:px-8 lg:pt-20">
    <div class="flex flex-1 items-center justify-start">
      <div class="max-w-3xl">
        <p class="text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-imc-yellow/85 sm:text-xs">Importación a tu medida</p>

        <h1 class="mt-6 max-w-4xl text-5xl font-semibold text-balance text-white sm:text-6xl lg:text-[5.7rem]">
          Tu coche ideal desde <span class="text-imc-yellow">Alemania</span> a España.
        </h1>

        <div class="mt-8 flex flex-col gap-4 sm:flex-row sm:items-center">
          <button
            type="button"
            data-open-contact-form
            class="inline-flex items-center justify-center gap-3 rounded-md bg-imc-yellow px-6 py-4 text-sm font-semibold text-[#271d08] transition hover:bg-[#e1c177] cursor-pointer"
          >
            Solicitar presupuesto
          </button>
        </div>
      </div>
    </div>

    <Rrss />

    <div class="flex flex-col items-center pb-14 pt-16 text-center text-[0.58rem] uppercase tracking-[0.38em] text-white/30">
      <span>Desliza para saber más</span>
      <span class="mt-4 h-10 w-px bg-[linear-gradient(180deg,rgba(255,255,255,0.35),rgba(255,255,255,0))]"></span>
    </div>
  </div>

  <div class="border-t border-white/6 bg-[#151313]/92 backdrop-blur-sm">
    <div class="mx-auto grid w-full max-w-7xl gap-px px-0 sm:grid-cols-3">
      <article class="flex items-start gap-4 bg-[#171414] px-6 py-7 lg:px-8">
        <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-imc-yellow/10 text-imc-yellow">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-5 w-5" aria-hidden="true">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M3 13l2-5a3 3 0 0 1 2.8-2h8.4A3 3 0 0 1 19 8l2 5M5 13h14m-13 0v4a1 1 0 0 0 1 1h1m10-5v4a1 1 0 0 1-1 1h-1M7 18h10"></path>
            <circle cx="7.5" cy="14.5" r="1" fill="currentColor" stroke="none"></circle>
            <circle cx="16.5" cy="14.5" r="1" fill="currentColor" stroke="none"></circle>
          </svg>
        </div>
        <div>
          <p class="text-base font-semibold text-white/90">Proceso de importación</p>
          <p class="mt-1 text-sm text-white/45">100% a tu medida</p>
        </div>
      </article>

      <article class="flex items-start gap-4 bg-[#171414] px-6 py-7 lg:px-8">
        <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-imc-yellow/10 text-imc-yellow">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-5 w-5" aria-hidden="true">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M12 3l2.65 2.7 3.73-.58.58 3.73L21.7 12l-2.74 2.15.58 3.73-3.73.58L12 21l-2.92-2.54-3.73.58.58-3.73L3.3 12l2.63-3.15-.58-3.73 3.73.58L12 3z"
            ></path>
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.5 12.3l1.6 1.6 3.4-3.6"></path>
          </svg>
        </div>
        <div>
          <p class="text-base font-semibold text-white/90">Revisión técnica</p>
          <p class="mt-1 text-sm text-white/45">Rigurosa y precisa</p>
        </div>
      </article>

      <article class="flex items-start gap-4 bg-[#171414] px-6 py-7 lg:px-8">
        <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-imc-yellow/10 text-imc-yellow">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-5 w-5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 7h11v8H3zM14 10h3l4 3v2h-7z"></path>
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M7 18a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3zm10 0a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3z"></path>
          </svg>
        </div>
        <div>
          <p class="text-base font-semibold text-white/90">Transporte</p>
          <p class="mt-1 text-sm text-white/45">Asegurado y rápido</p>
        </div>
      </article>
    </div>
  </div>
</section>
