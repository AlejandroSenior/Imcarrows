---
const links = [
  { label: 'Inventario', href: '#selection-search' },
  { label: 'Como funciona', href: '#hero' },
  { label: 'Servicios', href: '#technical-inspection' },
  { label: 'Testimonios', href: '#faqs' }
];
---

<header class="fixed inset-x-0 top-0 z-50 border-b border-white/10 bg-imc-black/80 backdrop-blur-xl">
  <nav class="mx-auto flex w-full max-w-6xl items-center justify-between px-6 py-4 lg:px-8">
    <div class="flex items-center gap-4">
      <img src="/imc-logo.webp" alt="Imcarrows Logo" class="w-10" />
      <a href="#hero" class="font-display text-lg uppercase tracking-[0.2em] text-imc-silver">Imcarrows</a>
    </div>

    <ul class="hidden items-center gap-8 text-sm uppercase tracking-[0.08em] text-imc-silver lg:flex">
      {
        links.map((link) => (
          <li>
            <a href={link.href} class="transition hover:text-imc-yellow">
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <button
      type="button"
      data-open-contact-form
      class="rounded-md border border-imc-yellow px-2 py-1 font-semibold bg-imc-yellow text-imc-black transition hover:bg-imc-red hover:text-white"
    >
      CONTACTAR
    </button>
  </nav>
</header>
