---
const links = [
  { label: 'Cómo funciona', href: '#steps' },
  { label: 'Servicios', href: '#services' },
  { label: 'Preguntas', href: '#faqs' }
];

const isHomePage = Astro.url.pathname === '/';
const brandHref = isHomePage ? '#hero' : '/';
const navLinks = links.map((link) => ({
  ...link,
  href: isHomePage ? link.href : `/${link.href}`
}));
---

<header class="fixed inset-x-0 top-0 z-50 border-b border-white/10 bg-imc-black/80 backdrop-blur-xl">
  <nav class="mx-auto flex w-full max-w-6xl items-center justify-between px-6 py-4 lg:px-8">
    <a href={brandHref} class="flex items-center gap-4">
      <img src="/imc-logo.webp" alt="Imcarrows Logo" class="w-10" />
      <p class="font-display text-lg uppercase tracking-[0.2em] text-imc-silver">Imcarrows</p>
    </a>

    <ul class="hidden items-center gap-8 text-sm uppercase tracking-[0.08em] text-imc-silver lg:flex">
      {
        navLinks.map((link) => (
          <li>
            <a href={link.href} class="transition hover:text-imc-yellow">
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <button
      type="button"
      data-open-contact-form
      class="rounded-md border border-imc-yellow px-4 py-1 font-semibold text-sm bg-imc-yellow text-imc-black hover:bg-[#e1c177] cursor-pointer"
    >
      CONTACTAR
    </button>
  </nav>
</header>
